{
  "name": "@rodrigoaraujotl/sdk-uappi",
  "version": "0.1.2",
  "description": "SDK TypeScript compatível com Next.js para consumo das APIs Front v2 da Uappi.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "rm -rf .test-build && tsc -p tsconfig.test.json && node --test test/",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "uappi",
    "wapstore",
    "sdk",
    "nextjs",
    "typescript"
  ],
  "author": "Rodrigo Araújo",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodrigoaraujotl/sdk-uappi"
  },
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.11"
  }
}
